{
  "name": "viandas-zarate",
  "version": "1.0.0",
  "private": true,
  "description": "App mobile-first para gestion de viandas con MongoDB y calendario operativo.",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node server/index.js",
    "dev:web": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "seed": "node server/seed.js"
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^4.5.3"
  }
}
